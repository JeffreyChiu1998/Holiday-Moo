# Holiday Moo Calendar - Environment Configuration
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual API keys and URLs
# 3. Never commit the .env file to version control (it's in .gitignore)
# 4. For production deployment, set these variables in your hosting environment

# =============================================================================
# AI SERVICE API KEYS (Required for Moo AI Chatbot)
# =============================================================================

# xAI (Grok) API Key - Powers the conversation controller AI
# Get your API key from: https://console.x.ai/
# Used for: Managing conversation flow, understanding user intent
REACT_APP_XAI_API_KEY=your-xai-api-key-here

# Perplexity AI API Key - Powers travel recommendations
# Get your API key from: https://www.perplexity.ai/settings/api
# Used for: Real-time travel advice and recommendations
REACT_APP_PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Google Maps API Key - Powers location services
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API, Geocoding API
# Used for: Location picker, maps in modals, place search
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================================
# AWS LAMBDA EXPORT SERVICE (Optional - for Excel export functionality)
# =============================================================================

# AWS API Gateway Endpoint URL
# Get this URL after running: setup-aws-lambda.bat
# Format: https://your-api-id.execute-api.us-east-1.amazonaws.com/prod/export
# Leave as placeholder if you haven't set up AWS Lambda yet
REACT_APP_EXPORT_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod/export

# Enable/disable the export service
# Set to 'false' if you don't want to use the Excel export feature
REACT_APP_EXPORT_SERVICE_ENABLED=true

# Request timeout for export service (milliseconds)
# Increase if you have large trips that take longer to export
REACT_APP_EXPORT_TIMEOUT=30000

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment mode
# Use 'development' for local development, 'production' for deployment
NODE_ENV=production

# =============================================================================
# OPTIONAL: DEVELOPMENT OVERRIDES
# =============================================================================

# Uncomment these for local development if needed
# REACT_APP_DEBUG_MODE=true
# REACT_APP_MOCK_AI_RESPONSES=false

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 
# - Never share your API keys publicly
# - Use environment-specific keys (dev/staging/prod)
# - Regularly rotate your API keys
# - Monitor API usage and set up billing alerts
# - The .env file is ignored by git for security
#
# For production deployment:
# - Set these variables in your hosting platform (Vercel, Netlify, etc.)
# - Use your hosting platform's environment variable settings
# - Never hardcode API keys in your source code